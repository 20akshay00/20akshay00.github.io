        "  color: { \n",
        "    scheme: \"blues\", \n",
        "    legend: false, \n",
        "    label: \"Cutoff (n)\"\n",
        "  },\n",
        "  marks: [\n",
        "    Plot.line(data, {\n",
        "      x: \"x\", \n",
        "      y: \"y\", \n",
        "      z: \"n\", \n",
